<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <!-- Define the Filters -->
  <filter>
    <filter-name>CorsFilter</filter-name>
    <filter-class>config.CorsFilter</filter-class>
  </filter>
  <filter>
    <filter-name>SessionCheckFilter</filter-name>
    <filter-class>config.SessionCheckFilter</filter-class>
  </filter>

  <!-- Map the Filters (Order of mapping dictates execution order) -->
  <filter-mapping>
    <filter-name>CorsFilter</filter-name>
    <url-pattern>/api/v1/*</url-pattern> <!-- Runs 1st -->
  </filter-mapping>

  <filter-mapping>
    <filter-name>SessionCheckFilter</filter-name>
    <url-pattern>/api/v1/*</url-pattern> <!-- Runs 2nd -->
  </filter-mapping>

</web-app>
